<launch>
    <rosparam command="load" file="$(find experiment)/config/experiment_params.yaml" />

    <arg name="experiment_type" default="1" /> 
  

    <node pkg="cv_basics" type="joy_repacker.py" name="joy_repacker"></node>
    
    <!-- <include file="/opt/ros/noetic/share/joy/launch/ps4joy.launch" /> -->

    <group if="$(eval arg('experiment_type') == 1)">
      <include file="$(find experiment)/launch/launch_experiment_1.launch" />
    </group>
   
    <group if="$(eval arg('experiment_type') == 2)">
      <include file="$(find experiment)/launch/launch_experiment_2.launch" />
    </group>

    <group if="$(eval arg('experiment_type') == 3)">
      <include file="$(find experiment)/launch/launch_experiment_3.launch" />
    </group>

    <group if="$(eval arg('experiment_type') == 4)">
      <include file="$(find experiment)/launch/launch_experiment_4.launch" />
    </group>

    <!-- <node pkg="cv_basics" type="record_node.py" name="record_experiment" output="screen"></node> -->
   
    


</launch> 